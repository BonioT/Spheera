    },
    "Date" : {
      "comment" : "A line that represents the stress level of the user over time.",
      "isCommentAutoGenerated" : true
    },
    "Don’t focus on one moment. Look at the whole calendar — it’s a small part of your life. Breathe. You’re okay." : {
      "comment" : "A piece of motivational text displayed below the calendar view in the `HistoryCalendar`.",
      "extractionState" : "stale",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Non concentrarti su un singolo momento. Guarda l'intero calendario — è solo una piccola parte della tua vita. Respira. Stai bene."
          }
        }
      }
    },
    "Don’t focus on one moment. Look at the whole timeline. Breathe. You’re okay." : {
      "comment" : "A placeholder text displayed in the history calendar when there are no entries for a selected day. It encourages the user to focus on the whole timeline and breathe.",
      "isCommentAutoGenerated" : true
    },
