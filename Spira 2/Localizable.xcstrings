  "strings" : {
    "%lld" : {
      "comment" : "A day number displayed in a calendar cell. The number is drawn in white on a background that is either slightly transparent or fully opaque, depending on whether the day belongs to the current month or not.",
      "isCommentAutoGenerated" : true
    },
    "A simple technique to ground yourself in the present." : {
      "localizations" : {
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una tecnica semplice per radicarti nel presente."
