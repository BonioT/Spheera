    "Don’t focus on one moment. Look at the whole calendar — it’s a small part of your life. Breathe. You’re okay." : {
      "comment" : "A piece of motivational text displayed below the calendar view in the `HistoryCalendar`.",
      "extractionState" : "stale",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Non concentrarti su un singolo momento. Guarda l'intero calendario — è solo una piccola parte della tua vita. Respira. Stai bene."
          }
        }
      }
    },
    "Don’t focus on one moment. Look at the whole timeline. Breathe. You’re okay." : {
      "comment" : "A placeholder text displayed in the history calendar when there are no entries for a selected day. It encourages the user to focus on the whole timeline and breathe.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Konzentrieren Sie sich nicht auf einen einzigen Moment. Betrachten Sie die gesamte Zeitachse. Atmen Sie. Es ist alles in Ordnung."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No te concentres en un solo momento. Mira toda la línea de tiempo. Respira. Estás bien."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ne vous concentrez pas sur un seul moment. Regardez toute la timeline. Respirez. Tout va bien."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Non concentrarti su un singolo momento. Guarda l'intera timeline. Respira. Stai bene."
          }
        }
      }
    },
